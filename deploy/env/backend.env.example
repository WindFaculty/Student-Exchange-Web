# Copy this file to /opt/student-exchange/shared/backend.env on VPS
# and replace values for production.

DB_URL=jdbc:mysql://<mysql-host>:3306/student_exchange?useUnicode=true&characterEncoding=utf8&connectionCollation=utf8mb4_vi_0900_ai_ci&connectionTimeZone=UTC&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=<db-username>
DB_PASSWORD=<db-password>
ZALO_APP_ID=<zalo-app-id>
ZALO_APP_SECRET=<zalo-app-secret>
ZALO_REDIRECT_URI=<https://your-domain/api/auth/zalo/callback>
APP_FRONTEND_BASE_URL=<https://your-frontend-domain>
