# Copy this file to /opt/student-exchange/shared/backend.env on VPS
# and replace values for production.

DB_URL=jdbc:mysql://<mysql-host>:3306/student_exchange?useUnicode=true&characterEncoding=utf8&connectionCollation=utf8mb4_vi_0900_ai_ci&connectionTimeZone=UTC&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=<db-username>
DB_PASSWORD=<db-password>
ZALO_APP_ID=<zalo-app-id>
ZALO_APP_SECRET=<zalo-app-secret>
ZALO_REDIRECT_URI=<https://your-domain/api/auth/zalo/callback>
APP_FRONTEND_BASE_URL=<https://your-frontend-domain>
AGENTIC_ENABLED=false
AGENTIC_INTERNAL_TOKEN=<strong-random-shared-token>
AGENTIC_INTERNAL_ALLOW_LOCALHOST=true
AGENTIC_SIDECAR_BASE_URL=http://127.0.0.1:18082
AGENTIC_SIDECAR_CONNECT_TIMEOUT_MS=2000
AGENTIC_SIDECAR_READ_TIMEOUT_MS=15000
AGENTIC_REDIS_URL=redis://redis:6379/0
AGENTIC_CODEX_API_KEY=<codex-api-key>
AGENTIC_CODEX_ENDPOINT=<https://codex-endpoint>
AGENTIC_CLAUDE_API_KEY=<claude-api-key>
AGENTIC_CLAUDE_ENDPOINT=<https://claude-endpoint>
AGENTIC_GEMINI_API_KEY=<gemini-api-key>
AGENTIC_GEMINI_ENDPOINT=<https://gemini-endpoint>
